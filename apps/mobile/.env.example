# API (no trailing slash). Android emulator default:
EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:4000

# Google OAuth Web 클라이언트 ID — API 서버의 GOOGLE_CLIENT_ID와 동일 권장.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# (권장) 웹 클라이언트 > 승인된 리디렉션 URI와 한 글자도 같게.
# 예: http://localhost:4000/v1/auth/google/mobile-callback
# 비우면: API가 http://10.0.2.2:4000 이면 OAuth용으로 자동으로 http://localhost:4000/... (에뮬+adb reverse)
# 실제 기기·LAN IP 등은 EXPO_PUBLIC_GOOGLE_OAUTH_REDIRECT_URI로 콘솔과 동일하게 명시.
EXPO_PUBLIC_GOOGLE_OAUTH_REDIRECT_URI=

# (선택) Android / iOS용 OAuth 클라이언트 ID.
# Android 클라이언트 등록 시 패키지명: com.lifenote.mobile (app.json과 동일해야 함)
# + 디버그/릴리스 keystore SHA-1. iOS는 bundleIdentifier 동일 값으로 번들 ID 등록.
# 콘솔에서 유형 "Android"(패키지명+SHA-1) / "iOS" 클라이언트를 만들면 해당 ID.
# 비워 두면 앱은 웹 클라이언트 ID를 네이티브 clientId로도 넘깁니다(개발 편의).
# Google이 네이티브에서 웹 클라이언트만 거부하면 아래를 채우세요.
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
