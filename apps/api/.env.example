# PostgreSQL (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/lifenote?schema=public"

# migrate dev 가 P3014(shadow DB 생성 불가)일 때 — 택1
# (A) DB 역할에 생성 권한 부여(슈퍼유저에서 1회): ALTER ROLE "USER" CREATEDB;
# (B) 관리자가 빈 DB 하나를 미리 만들고, prisma/schema.prisma datasource 에
#     shadowDatabaseUrl = env("SHADOW_DATABASE_URL") 추가 후 아래 설정
# SHADOW_DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/lifenote_shadow?schema=public"
# (C) 마이그레이션 파일 없이 스키마만 맞출 때: npm run prisma:push

# API (웹 기본 3000과 겹치지 않게 4000 권장)
PORT=4000

# CORS — 쉼표로 여러 출처 허용 (로컬 Next 등)
CORS_ORIGIN=http://localhost:3000

# JWT (HS256) — 프로덕션에서는 충분히 긴 무작위 문자열
JWT_SECRET="change-me-to-a-long-random-secret-at-least-32-chars"
JWT_ACCESS_EXPIRES_SEC=3600
JWT_REFRESH_EXPIRES_SEC=2592000

# Google OAuth (서버에서 authorization code 교환)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
