{
  "name": "lifenote",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:api": "npm run start:dev -w api",
    "dev:web": "npm run dev -w web",
    "dev:mobile": "npm run start -w mobile",
    "build:api": "npm run build -w api",
    "build:web": "npm run build -w web",
    "build": "npm run build:api && npm run build:web"
  }
}
